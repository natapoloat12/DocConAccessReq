# Environment Variables Template

# --- FortiGate Integration ---
FORTIGATE_BASE_URL=https://10.0.0.1
FORTIGATE_API_TOKEN=your_token_here
FORTIGATE_VERIFY_SSL=true

# --- LDAP Authentication ---
LDAP_URL=ldap://your-ad-server:389
LDAP_DOMAIN=yourdomain.co.th

# --- Session Security ---
JWT_SECRET=generate_a_long_random_string_here
COOKIE_SECURE=true
ALLOWED_ORIGIN=https://firewall.yourdomain.com

# --- Email Notifications (SMTP) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=service-account@domain.com
SMTP_PASS=password_here
SMTP_FROM=service-account@domain.com
SMTP_TO=admin@domain.com
SMTP_CC=team@domain.com
